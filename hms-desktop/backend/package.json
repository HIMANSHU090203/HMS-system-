{
  "name": "hms-backend",
  "version": "1.0.0",
  "description": "HMS Desktop Application Backend API",
  "main": "dist/index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon --exec ts-node api/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "ts-node prisma/seed.ts",
    "backfill:prescription-totals": "ts-node api/scripts/backfill-prescription-totals.ts",
    "lint": "eslint api/**/*.ts",
    "lint:fix": "eslint api/**/*.ts --fix",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:reload": "pm2 reload ecosystem.config.cjs",
    "pm2:stop": "pm2 stop zenhosp-api",
    "pm2:delete": "pm2 delete zenhosp-api",
    "pm2:status": "pm2 status",
    "pm2:logs": "pm2 logs zenhosp-api --lines 100"
  },
  "keywords": [
    "hms",
    "hospital",
    "management",
    "system",
    "api"
  ],
  "author": "HMS Development Team",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "@types/express": "^5.0.3",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.7.2",
    "@types/winston": "^2.4.4",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.11.0",
    "multer": "^2.0.2",
    "node-cron": "^3.0.3",
    "pdf-parse": "^2.4.5",
    "typescript": "^5.9.3",
    "winston": "^3.18.3",
    "xlsx": "^0.18.5",
    "zod": "^4.1.12",
    "axios": "^1.7.9"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^6.0.3",
    "jest": "^30.2.0",
    "nodemon": "^3.1.10",
    "prisma": "^6.19.0",
    "supertest": "^7.1.4",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2"
  }
}
