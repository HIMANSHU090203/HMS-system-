# ============================================
# HMS Backend Environment Configuration
# ============================================
# Copy this file to .env and update with your actual values
# NEVER commit .env to version control
# ============================================

# ============================================
# DATABASE CONFIGURATION (REQUIRED)
# ============================================
# PostgreSQL connection string
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/hms_database"

# Alternative: Individual database settings (if not using DATABASE_URL)
# DATABASE_USER="postgres"
# DATABASE_PASSWORD="your_password"
# DATABASE_HOST="localhost"
# DATABASE_PORT="5432"
# DATABASE_NAME="hms_database"

# ============================================
# JWT CONFIGURATION (REQUIRED)
# ============================================
# JWT Secret for signing access tokens (REQUIRED)
# Generate a secure random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your_secure_jwt_secret_min_32_characters_long"

# JWT Refresh Secret for signing refresh tokens (OPTIONAL but RECOMMENDED)
# Must be different from JWT_SECRET
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_REFRESH_SECRET="your_secure_refresh_secret_min_32_characters_long"

# Token expiration times (OPTIONAL - defaults shown)
JWT_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="7d"

# ============================================
# SERVER CONFIGURATION (OPTIONAL)
# ============================================
# Server port (default: 3000)
PORT="3000"

# Environment: development, production, test
NODE_ENV="development"

# CORS origin (default: '*' for Electron apps)
# For production, specify exact origins
CORS_ORIGIN="*"

# ============================================
# APPLICATION CONFIGURATION (OPTIONAL)
# ============================================
APP_NAME="HMS Desktop"
APP_VERSION="1.0.0"
HOSPITAL_NAME="Your Hospital Name"

# ============================================
# SECURITY CONFIGURATION (OPTIONAL)
# ============================================
# Bcrypt rounds for password hashing (default: 12)
# Higher = more secure but slower (12-15 recommended)
BCRYPT_ROUNDS="12"

# ============================================
# LOGGING CONFIGURATION (OPTIONAL)
# ============================================
# Log level: error, warn, info, debug (default: info in production, debug in development)
LOG_LEVEL="info"

# ============================================
# CURRENCY CONFIGURATION (OPTIONAL)
# ============================================
# Enable currency exchange rate scheduler (default: true)
# Set to 'false' to disable automatic currency rate updates
ENABLE_CURRENCY_SCHEDULER="true"

# Fixer.io API key (OPTIONAL - for currency rate updates)
# If not provided, uses free exchangerate-api.com
FIXER_API_KEY=""

# Timezone for currency scheduler (default: UTC)
TZ="UTC"

# ============================================
# FILE UPLOAD CONFIGURATION (OPTIONAL)
# ============================================
# Maximum file upload size (default: 10MB)
MAX_FILE_SIZE="10MB"

# Upload directory path (relative to backend root)
UPLOAD_PATH="./uploads"

# ============================================
# EMAIL CONFIGURATION (OPTIONAL - Future use)
# ============================================
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-password"

# ============================================
# NOTES
# ============================================
# 1. Generate secure JWT secrets using:
#    node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# 2. For production:
#    - Use strong, unique JWT secrets
#    - Set NODE_ENV="production"
#    - Configure specific CORS_ORIGIN
#    - Use secure DATABASE_URL with strong password
#
# 3. Required variables:
#    - DATABASE_URL (or individual DB settings)
#    - JWT_SECRET
#
# 4. Recommended variables:
#    - JWT_REFRESH_SECRET (enables refresh token functionality)
#    - HOSPITAL_NAME
#    - NODE_ENV
