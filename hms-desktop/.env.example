# ============================================
# HMS Frontend Environment Configuration
# ============================================
# Copy this file to .env and update with your actual values
# NEVER commit .env to version control
# Note: Vite requires VITE_ prefix for environment variables
# ============================================

# ============================================
# API CONFIGURATION (OPTIONAL)
# ============================================
# Backend API URL (default: http://localhost:3000/api)
# For production, use your server's URL
VITE_API_URL="http://localhost:3000/api"

# ============================================
# APPLICATION CONFIGURATION (OPTIONAL)
# ============================================
# Application name (default: HMS Desktop)
VITE_APP_NAME="HMS Desktop"

# Application version (default: 1.0.0)
VITE_APP_VERSION="1.0.0"

# Hospital name (default: Your Hospital Name)
VITE_HOSPITAL_NAME="Your Hospital Name"

# ============================================
# DEVELOPMENT CONFIGURATION (OPTIONAL)
# ============================================
# Enable debug mode (default: false)
# Set to 'true' for additional console logging
VITE_DEBUG="false"

# Enable logging (default: false)
VITE_ENABLE_LOGGING="false"

# ============================================
# FEATURE FLAGS (OPTIONAL)
# ============================================
# Enable offline mode (default: false)
# Allows app to work without backend connection
VITE_ENABLE_OFFLINE_MODE="false"

# Enable analytics (default: false)
# For future analytics integration
VITE_ENABLE_ANALYTICS="false"

# ============================================
# NOTES
# ============================================
# 1. All Vite environment variables MUST start with VITE_
# 2. Variables are available in code via: import.meta.env.VITE_VARIABLE_NAME
# 3. After changing .env, restart the Vite dev server
# 4. For production builds, these values are baked into the bundle
# 5. Most variables have sensible defaults and are optional
